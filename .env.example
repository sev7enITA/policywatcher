# PolicyWatcher v3.0 Environment Configuration

# Google Gemini AI
GEMINI_API_KEY=your_gemini_api_key_here

# SMTP Configuration (Email Notifications)
# Works with any SMTP provider: Gmail, SendGrid, Postfix, etc.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM="PolicyWatcher <noreply@policywatcher.app>"

# Security
# High-entropy bearer token for cron/scrape/health operational endpoints.
# Generate a unique value for every environment. Do not reuse examples from docs or scripts.
API_SECRET=
SESSION_HMAC_SECRET=

# Application
# Your production domain (used in email links)
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Development-only database setup endpoint. Leave unset in production.
ALLOW_DATABASE_SEED_ENDPOINT=

# Rate-limit identity. Leave unset unless your proxy is verified to overwrite forwarded headers.
TRUST_PROXY_HEADERS=
TRUSTED_CLIENT_IP_HEADER=

# Admin Dashboard Credentials
ADMIN_USER=admin
ADMIN_PASSWORD=your_strong_admin_password
AUDITOR_USER=auditor
AUDITOR_PASSWORD=your_auditor_password
