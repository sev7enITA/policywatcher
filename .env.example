# PolicyWatcher v2.0 Environment Configuration

# Google Gemini AI
GEMINI_API_KEY=your_gemini_api_key_here

# SMTP Configuration (Email Notifications)
# Works with any SMTP provider: Gmail, SendGrid, Postfix, etc.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM="PolicyWatcher <noreply@policywatcher.app>"

# Security
# Used to protect the /api/cron/check-all endpoint
API_SECRET=generate_a_random_secret_here

# Application
# Your production domain (used in email links)
APP_URL=http://localhost:3000
